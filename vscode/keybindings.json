[
// basic posix-like editing
{
    "key": "alt+b",
    "command": "cursorWordLeft",
},

{
    "key": "alt+f",
    "command": "cursorWordRight",
},

{
    "key": "alt+;",
    "command": "workbench.action.previousEditorInGroup",
},

{
    "key": "alt+'",
    "command": "workbench.action.nextEditorInGroup",
},

{
    "key": "alt+d",
    "command": "deleteWordRight",
},

{
    "key": "alt+n",
    "command": "runCommands",
    "args": {
        "commands": [
            {
                "command": "editor.actions.findWithArgs",
                "args": {
                    "searchString": "^\\s*$",
                    "isRegex": true,
                    "matchWholeWord": false,
                    "isCaseSensitive": false
                }
            },
            {
                "command": "editor.action.nextMatchFindAction"
            },
            {
                "command": "closeFindWidget"
            }
        ]
    }
},

{
    "key": "alt+p",
    "command": "runCommands",
    "args": {
        "commands": [
            {
                "command": "editor.actions.findWithArgs",
                "args": {
                    "searchString": "^\\s*$",
                    "isRegex": true,
                    "matchWholeWord": false,
                    "isCaseSensitive": false
                }
            },
            {
                "command": "editor.action.previousMatchFindAction"
            },
            {
                "command": "closeFindWidget"
            }
        ]
    }
},

{
    "key": "alt+down",
    "command": "runCommands",
    "args": {
        "commands": [
            {
                "command": "editor.actions.findWithArgs",
                "args": {
                    "searchString": "^\\s*$",
                    "isRegex": true,
                    "matchWholeWord": false,
                    "isCaseSensitive": false
                }
            },
            {
                "command": "editor.action.nextMatchFindAction"
            },
            {
                "command": "closeFindWidget"
            }
        ]
    }
},

{
    "key": "alt+up",
    "command": "runCommands",
    "args": {
        "commands": [
            {
                "command": "editor.actions.findWithArgs",
                "args": {
                    "searchString": "^\\s*$",
                    "isRegex": true,
                    "matchWholeWord": false,
                    "isCaseSensitive": false
                }
            },
            {
                "command": "editor.action.previousMatchFindAction"
            },
            {
                "command": "closeFindWidget"
            }
        ]
    }
},

{
    "key": "ctrl+d",
    "command": "deleteRight",
},

{
    "key": "ctrl+w",
    "command": "editor.action.clipboardCutAction",
},

{
    "key": "alt+w",
    "command": "editor.action.clipboardCopyAction",
},

{
    "key": "ctrl+y",
    "command": "editor.action.clipboardPasteAction",
},

{
    "key": "ctrl+k",
    "command": "editor.action.clipboardCutAction",
},

{
    "key": "ctrl+shift+x",
    "command": "editor.action.clipboardCutAction",
},

{
    "key": "ctrl+shift+c",
    "command": "editor.action.clipboardCopyAction",
},

{
    "key": "ctrl+shift+v",
    "command": "editor.action.clipboardPasteAction",
},

{
    "key": "ctrl+shift+-",
    "command": "undo",
},

{
    "key": "ctrl+z",
    "command": "undo",
},

{
    "key": "ctrl+shift+z",
    "command": "redo",
},

// search & replace
{
    "key": "cmd+f",
    "command": "actions.find",
},

{
    "key": "alt+h",
    "command": "editor.action.startFindReplaceAction"
},

{
    "key": "meta+h",
    "command": "editor.action.startFindReplaceAction"
},

// sidebar & navigation
{
    "key": "meta+b",
    "command": "workbench.action.toggleSidebarVisibility",
},

{
    "key": "meta+p",
    "command": "workbench.action.quickOpen",
},

{
    "key": "cmd+shift+p",
    "command": "workbench.action.showCommands",
},

{
    "key": "cmd+s",
    "command": "workbench.action.files.save"
},

// disable mission control shortcuts on macos
{
    "key": "ctrl+left",
    "command": "cursorWordLeft",
},

{
    "key": "ctrl+right",
    "command": "cursorWordRight",
},

{
    "key": "ctrl+shift+left",
    "command": "cursorWordLeftSelect",
},

{
    "key": "ctrl+shift+right",
    "command": "cursorWordRightSelect",
},

{
    "key": "ctrl+up",
    "command": "scrollPageUp",
},

{
    "key": "ctrl+down",
    "command": "scrollPageDown",
},

// *** alt+x ... (keyd sends alt+x when ctrl+x is pressed in vscode) ***
{
    "key": "alt+x f",
    "command": "workbench.action.quickOpen",
},

{
    "key": "alt+x s",
    "command": "workbench.action.files.save",
},

{
    "key": "alt+x ctrl+s",
    "command": "workbench.action.files.save",
},

{
    "key": "alt+x ctrl+f",
    "command": "workbench.action.quickOpen",
},

{
    "key": "alt+x ctrl+r",
    "command": "workbench.action.openRecent",
},

{
    "key": "alt+x b",
    "command":"workbench.action.quickOpen",
},

{
    "key": "alt+x 1",
    "command": "workbench.action.joinTwoGroups",
},

{
    "key": "alt+x 2",
    "command": "workbench.action.splitEditor",
},

{
    "key": "alt+x 3",
    "command": "workbench.action.splitEditorDown",
},

{
    "key": "alt+x 0",
    "command": "workbench.action.closeAllEditors",
},

// *** code completion and navigation: alt+c (keyd sends alt+c for ctrl+c) ***
{
    "key": "alt+c c",
    "command": "editor.action.triggerSuggest",
},

{
    "key": "alt+c g",
    "command": "workbench.action.gotoSymbol",
},

{
    "key": "alt+c d",
    "command": "editor.action.revealDefinition",
},

{
    "key": "alt+c a",
    "command": "editor.action.codeAction",
},

{
    "key": "alt+c f",
    "command": "editor.action.formatDocument",
},

{
    "key": "alt+c i",
    "command": "editor.action.goToImplementation",
},

{
    "key": "alt+c j",
    "command": "editor.action.revealDeclaration",
},

{
    "key": "alt+c r",
    "command": "editor.action.rename",
},

{
    "key": "alt+c ctrl+f",
    "command": "editor.action.formatDocument",
},

{
    "key": "alt+c shift+,",
    "command": "outdentLines",
},

{
    "key": "alt+c shift+.",
    "command": "editor.action.indentLines",
},

{
    "key": "alt+c x",
    "command": "editor.action.referenceSearch.trigger",
},

{
    "key": "alt+c b",
    "command": "editor.debug.action.toggleBreakpoint",
},

{
    "key": "alt+l",
    "command": "workbench.action.gotoLine",
},

{
    "key": "meta+g",
    "command": "workbench.action.showAllSymbols",
},

// *** testing and debugging: alt+t (keyd sends alt+t for ctrl+t) ***
{
    "key": "alt+t c",
    "command": "testing.debugAtCursor",
},

{
    "key": "alt+t f",
    "command": "testing.runCurrentFile",
},

{
    "key": "alt+t l",
    "command": "testing.debugLastRun",
},

{
    "key": "alt+t r", // resume
    "command": "workbench.action.debug.continue",
},

{
    "key": "alt+t s",
    "command": "workbench.action.debug.stop",
},

{
    "key": "alt+t d",
    "command": "workbench.action.debug.start",
},

{
    "key": "alt+t b",
    "command": "debug.toggleBreakpoint",
},

// more muscle memory bindings from emacs config
{
    "key": "alt+left",
    "command": "workbench.action.focusLeftGroup",
},

{
    "key": "alt+,",
    "command": "workbench.action.focusLeftGroup",
},

{
    "key": "alt+right",
    "command": "workbench.action.focusRightGroup",
},

{
    "key": "alt+.",
    "command": "workbench.action.focusRightGroup",
},

{
    "key": "alt+o",
    "command": "workbench.action.focusNextGroup",
},

{
    "key": "alt+/",
    "command": "workbench.action.focusNextGroup",
},

{
    "key": "alt+q",
    "command": "C_Cpp.SwitchHeaderSource",
},

]
